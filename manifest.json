{
  "manifest_version": 3,
  "name": "Take a Break",
  "version": "1.0",

  "icons": {
    "16": "icons/bone-broken-svgrepo-com.svg",
    "32": "icons/bone-broken-svgrepo-com.svg",
    "48": "icons/bone-broken-svgrepo-com.svg",
    "128": "icons/bone-broken-svgrepo-com.svg"
  },

  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": {
      "16": "icons/bone-broken-svgrepo-com.svg",
      "32": "icons/bone-broken-svgrepo-com.svg",
      "48": "icons/bone-broken-svgrepo-com.svg",
      "128": "icons/bone-broken-svgrepo-com.svg"
    },
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "overlay_video/cat.mp4"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}